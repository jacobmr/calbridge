{
  "cleanUrls": true,
  "functions": {
    "api/**/*.mjs": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/b/:host/:event",
      "destination": "/book/?host=:host&event=:event"
    },
    {
      "source": "/poll/:token",
      "destination": "/poll/?token=:token"
    },
    {
      "source": "/api/groups/:id/feed.ics",
      "destination": "/api/groups/:id/feed"
    },
    {
      "source": "/webhook",
      "destination": "/api/billing/webhook"
    },
    {
      "source": "/webhook/",
      "destination": "/api/billing/webhook"
    }
  ]
}
