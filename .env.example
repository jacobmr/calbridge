# Database (Turso / libSQL). For local dev use a file URL: file:./.calbridge.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Encryption (each value is a base64-encoded 32-byte random key)
CALBRIDGE_DEK=
SESSION_SIGNING_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mical.net/api/oauth/google/callback

# Microsoft Graph OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://mical.net/api/oauth/microsoft/callback

# App
APP_BASE_URL=https://mical.net
CRON_SECRET=
INTERNAL_DISPATCH_HMAC=

# Outbound email (Resend). Optional — if unset, group invitations fall
# back to a copy-the-link flow in the UI. Get a key at https://resend.com.
# EMAIL_FROM must use a domain verified in your Resend account.
RESEND_API_KEY=
EMAIL_FROM=MiCal <noreply@mical.net>
